{
  "manifest_version": 3,
  "name": "Blackjack Advisor",
  "version": "1.1",
  "description": "Real-time blackjack advice for Bovada live dealer",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://www.bovada.lv/*",
    "https://reallivedealercasino.com/*",
    "https://api.anthropic.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.bovada.lv/*",
        "https://reallivedealercasino.com/*"
      ],
      "js": ["content.js"],
      "css": ["overlay.css"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Blackjack Advisor"
  },
  "icons": {
    "16":  "icon.png",
    "48":  "icon.png",
    "128": "icon.png"
  }
}
